    </Variables>
    <Imports>
        <!-- Project Specific -->
        <Import>./Source/Scripts</Import>
        <Import>./Source/Scripts/SkyUI_SDK</Import>

        <!-- Base Game & Script Extender - ADJUST THESE PATHS -->
